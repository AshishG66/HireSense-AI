# Server Port
PORT=5000

# PostgreSQL Connection String (used by Prisma)
DATABASE_URL="postgresql://postgres:password@localhost:5432/hiresense?schema=public"

# AI Service Endpoint URL
AI_SERVICE_URL="http://localhost:8000"

# Gemini API Key (Can be passed directly or used in the AI Service)
GEMINI_API_KEY="your-google-gemini-api-key-here"

# JWT Authentication Configuration
JWT_SECRET="your-super-secure-jwt-secret-key-at-least-32-chars"
JWT_EXPIRES_IN="1d"
